rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // ── Admin users ─────────────────────────────────────────────────────────
    match /admin_users/{uid} {
      allow read: if isAdmin();
      allow write: if false; // managed via Firebase Console only
    }

    // ── Users ───────────────────────────────────────────────────────────────
    // Each user can read/write their own document; admins can read all.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid);
    }

    // ── Deals ───────────────────────────────────────────────────────────────
    match /deals/{dealId} {
      allow read: if isSignedIn();
      allow write: if false; // backend service account only
    }

    // ── Products (price-tracker) ────────────────────────────────────────────
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /price_history/{historyId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // ── Price tracker (legacy path) ─────────────────────────────────────────
    match /price_tracker/{productDocId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /price_history/{historyId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // ── Price change events ─────────────────────────────────────────────────
    match /price_change_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Price alerts ────────────────────────────────────────────────────────
    match /price_alerts/{alertId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create, update: if false; // backend only
    }

    // ── Scraper health ──────────────────────────────────────────────────────
    match /scraper_health/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Sources (scraper config) ────────────────────────────────────────────
    match /sources/{sourceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Groups ──────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Notification log ────────────────────────────────────────────────────
    match /notification_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Analytics ───────────────────────────────────────────────────────────
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /analytics_events/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Scraper control ─────────────────────────────────────────────────────
    match /scraper_control/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Admin collection ────────────────────────────────────────────────────
    match /admin/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
