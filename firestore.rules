rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Admin check uses email as document key (admin_users/user@email.com)
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin_users/$(request.auth.token.email));
    }

    // ── Admin users ─────────────────────────────────────────────────────────
    match /admin_users/{email} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Users ───────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid);
    }

    // ── Deals — any signed-in user can read; scraper writes via service account
    match /deals/{dealId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /price_history/{historyId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // ── Products (price-tracker) ────────────────────────────────────────────
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /price_history/{historyId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // ── Price tracker (legacy path) ─────────────────────────────────────────
    match /price_tracker/{productDocId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /price_history/{historyId} {
        allow read: if isSignedIn();
        allow write: if false;
      }
    }

    // ── Price change events ─────────────────────────────────────────────────
    match /price_change_events/{eventId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Price alerts ────────────────────────────────────────────────────────
    match /price_alerts/{alertId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.user_id == request.auth.uid);
      // Users create their own alerts (user_id must match their uid).
      allow create: if isSignedIn() &&
        request.resource.data.user_id == request.auth.uid;
      // Users can soft-delete (update is_active=false) their own alerts.
      allow update: if isAdmin() ||
        (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.user_id == request.auth.uid);
    }

    // ── Scraper health ──────────────────────────────────────────────────────
    match /scraper_health/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Sources (scraper config) ────────────────────────────────────────────
    match /sources/{sourceId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── User groups ─────────────────────────────────────────────────────────
    match /user_groups/{groupId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Notification log ────────────────────────────────────────────────────
    match /notification_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Notifications ───────────────────────────────────────────────────────
    match /notifications/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Analytics ───────────────────────────────────────────────────────────
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /analytics_events/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Scraper control ─────────────────────────────────────────────────────
    match /scraper_control/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Admin collection ────────────────────────────────────────────────────
    match /admin/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
