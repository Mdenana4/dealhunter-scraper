FROM python:3.11-slim-bookworm
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 curl ca-certificates libxml2 libxslt1.1 \
    && rm -rf /var/lib/apt/lists/*
COPY scraper_requirements.txt .
RUN pip install --no-cache-dir -r scraper_requirements.txt
COPY price_tracker_cloudrun.py ./
COPY price_tracker_job.py ./
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
CMD ["python3", "price_tracker_job.py"]
